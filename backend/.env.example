# =====================================================
# BACKEND ENVIRONMENT VARIABLES
# Set these in your Render dashboard under Environment
# =====================================================

PORT=5000

# MongoDB Atlas connection string (NOT localhost!)
# Get from: https://cloud.mongodb.com -> Connect -> Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smart-food-rescue?retryWrites=true&w=majority

# JWT Secret - use a strong random string (min 32 chars)
JWT_SECRET=replace_this_with_a_very_long_random_secret_string

# Cloudinary - required for production image uploads
# Get from: https://cloudinary.com -> Dashboard
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email - Brevo (Highly Recommended for Render) or SMTP Fallback
# Get Brevo API Key from: https://brevo.com -> API Keys
EMAIL_PROVIDER=smtp       # Options: 'smtp', 'brevo'
EMAIL_API_KEY=your_api_key_here
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# Your Vercel frontend URL (set after deploying frontend)
FRONTEND_URL=https://your-project-name.vercel.app
